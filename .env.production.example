MYSQL_DATABASE=smart_harvester
MYSQL_USER=smart_harvester
MYSQL_PASSWORD=replace-with-strong-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

REDIS_PASSWORD=replace-with-strong-redis-password

JWT_SECRET=replace-with-at-least-32-random-characters-please-change
METRICS_TOKEN=replace-with-at-least-24-random-characters
JWT_TTL_MINUTES=60

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
DISPATCHER_USERNAME=dispatcher
DISPATCHER_PASSWORD=replace-with-strong-dispatcher-password
DRIVER_USERNAME=driver
DRIVER_PASSWORD=replace-with-strong-driver-password
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=replace-with-strong-viewer-password

MQTT_USERNAME=smart-harvester
MQTT_PASSWORD=replace-with-strong-mqtt-password
MQTT_CLIENT_ID=smart-harvester-prod
MQTT_SSL_ENABLED=false

EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=replace-with-strong-emqx-dashboard-password

APP_CORS_ALLOWED_ORIGINS=https://your-domain.example,http://localhost
VITE_API_BASE_URL=
VITE_API_MODE=real
VITE_BACKEND_TARGET=https://your-api-origin.example
VITE_WS_URL=wss://your-api-origin.example/ws
VITE_BAIDU_MAP_AK=replace-with-baidu-map-ak
VITE_AMAP_KEY=replace-with-amap-key
VITE_OPENWEATHER_API_KEY=replace-with-openweather-key

AI_VISION_MODE=demo
NAVIGATION_MODE=demo
CONTROL_MODE=demo
SENSOR_SIMULATOR_INTERVAL_MS=5000
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
