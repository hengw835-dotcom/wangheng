function numberText(value) {
  const number = Number(value || 0)
  return Number.isInteger(number) ? String(number) : number.toFixed(1)
}

function countStatus(statuses) {
  if (usingDemoMachines.value) {
    if (statuses.includes('ERROR')) return 6
    if (statuses.includes('OFFLINE')) return 2
    if (statuses.includes('WORKING') && statuses.length === 1) return 10
    return 96
  }
  return machines.value.filter(item => statuses.includes(item.status)).length
}

function taskProgress(task) {
  const target = Number(task.targetArea || 0)
  if (!target) return 0
  return Math.min(100, Math.round(Number(task.completedArea || 0) / target * 100))
}

function machineStatusLabel(status) {
  return { ONLINE: '运行中', WORKING: '作业中', IDLE: '空闲待命', OFFLINE: '离线', ERROR: '异常', MAINTENANCE: '维护中' }[status] || status || '未设置'
}

function machineTone(status) {
  if (['ONLINE', 'WORKING', 'IDLE'].includes(status)) return 'green'
  if (status === 'ERROR') return 'red'
  if (status === 'MAINTENANCE') return 'yellow'
  return 'gray'
}

function auditTone(status) {
  if (['PUBLISHED', 'ACKNOWLEDGED'].includes(status)) return 'green'
  if (['FAILED', 'REJECTED'].includes(status)) return 'red'
  return 'yellow'
}

function sensorLabel(type) {
  return { temperature: '温度', humidity: '湿度', speed: '速度', engine_rpm: '转速', fuel_level: '燃油', pressure: '压力' }[type] || type || '未知'
}

function formatShortTime(value) {
  if (!value) return '-'
  return new Date(value).toLocaleTimeString('zh-CN', { hour12: false, hour: '2-digit', minute: '2-digit' })
}

function hashText(text) {
  return [...text].reduce((sum, char) => sum + char.charCodeAt(0) * 17, 0)
}

async function refreshAll() {
  await Promise.allSettled([
    machineStore.fetchMachines(),
    taskStore.fetchTasks(),
    systemStore.checkHealth(),
    refreshEmqx(),
    refreshAudits(),
    refreshSimulator(),
    refreshSensors()
  ])
  if (!selectedMachineId.value && machines.value.length) selectedMachineId.value = machines.value[0].machineId
}

async function refreshEmqx() {
  const { data } = await axios.get('/api/emqx/status')
  Object.assign(emqx, data)
}

async function refreshAudits() {
  const { data } = await axios.get('/api/emqx/control-audits')
  audits.value = Array.isArray(data) ? data : []
}

async function refreshSimulator() {
  const { data } = await axios.get('/api/sensor-simulator/status')
  Object.assign(simulatorStatus, data)
}

async function refreshSensors() {
  const { data: ids } = await axios.get('/api/sensor-data/machines')
  selectedSensorMachine.value = ids[ids.length - 1] || ''
  if (!selectedSensorMachine.value) {
    sensorRecords.value = []
    return
  }
  const { data } = await axios.get(`/api/sensor-data/machine/${encodeURIComponent(selectedSensorMachine.value)}`)
  sensorRecords.value = Array.isArray(data) ? data : []
}

async function sendCommand(command, parameters = {}) {
  const key = `${Date.now()}-${crypto.randomUUID?.() || Math.random().toString(16).slice(2)}`
  const { data } = await axios.post(`/api/emqx/machines/${encodeURIComponent(selectedMachineId.value)}/control`, {
    command,
    parameters
  }, {
    headers: { 'Idempotency-Key': key }
  })
  ElMessage.success(`命令已提交：${data.status}`)
  await refreshAudits()
}

async function publishSensor() {
  await axios.post('/api/sensor-simulator/publish', { ...simulator })
  simulatorLogs.value.unshift({ time: formatShortTime(new Date()), message: `${sensorLabel(simulator.sensorType)} ${simulator.value}${simulator.unit} 发布成功` })
  simulatorLogs.value = simulatorLogs.value.slice(0, 4)
  await Promise.allSettled([refreshSimulator(), refreshSensors()])
}

function selectVisionImage(event) {
  const file = event.target.files?.[0]
  visionFile.value = file || null
  visionResults.value = []
  if (visionPreview.value) URL.revokeObjectURL(visionPreview.value)
  visionPreview.value = file ? URL.createObjectURL(file) : ''
}

async function detectVision() {
  if (!visionFile.value) return
  visionLoading.value = true
  try {
    const body = new FormData()
    body.append('image', visionFile.value)
    const { data } = await axios.post('/api/ai-vision/detect', body)
    visionResults.value = Array.isArray(data) ? data : []
    ElMessage.success('识别完成')
  } finally {
    visionLoading.value = false
  }
}

